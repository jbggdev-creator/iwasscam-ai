# App
ENVIRONMENT=development
DEBUG=true
LOG_FORMAT=text

# Database (Supabase session pooler URL)
DATABASE_URL=postgresql+asyncpg://postgres.PROJECTREF:PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
SECRET_KEY=change-me-run-openssl-rand-hex-32

# CORS
FRONTEND_URL=http://localhost:3000

# AI / LLM (set USE_LLM=true only if you have Ollama running)
USE_LLM=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# Threat intelligence
URLHAUS_ENABLED=true
PHISHTANK_API_KEY=

# Security (optional)
CLAMAV_ENABLED=false
SENTRY_DSN=

# Observability (optional)
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
OTEL_ENABLED=false
OTEL_ENDPOINT=
